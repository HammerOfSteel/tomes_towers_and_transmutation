{
  "name": "tomes-towers-and-transmutation",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:report": "playwright show-report tests/e2e/report",
    "test:models": "playwright test --config=playwright.model-review.config.ts",
    "test:models:report": "playwright show-report tests/e2e/report-model-review",
    "fix:glb": "node scripts/fix-glb-materials.mjs",
    "coverage": "vitest run --coverage",
    "manifest": "node scripts/gen-manifest.mjs",
    "extract:chars": "node scripts/extract-char-assets.mjs",
    "gen:char-manifest": "node scripts/gen-char-manifest.mjs",
    "setup:chars": "npm run extract:chars && npm run gen:char-manifest",
    "bot": "npx tsx tests/bot/BotLauncher.ts",
    "bot:watch": "npx tsx tests/bot/BotLauncher.ts --headed --slow-mo 500",
    "bot:ci": "npx tsx tests/bot/BotLauncher.ts --headless --slow-mo 0",
    "bot:diff": "node tests/bot/screenshotDiff.mjs",
    "bot:baseline": "node tests/bot/screenshotDiff.mjs --update-baseline"
  },
  "dependencies": {
    "@dimforge/rapier3d-compat": "^0.14.0",
    "postprocessing": "^6.39.2",
    "three": "^0.170.0",
    "tweakpane": "^4.0.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@playwright/test": "^1.61.1",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^26.1.1",
    "@types/three": "^0.170.0",
    "autoprefixer": "^10.5.4",
    "daisyui": "^3.9.4",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.0.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.19",
    "prettier": "^3.3.0",
    "tailwindcss": "^3.4.19",
    "ts-node": "^10.9.2",
    "tsx": "^4.23.1",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0",
    "canvas": "^2.11.2"
  }
}